{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pain_record.schema.json",
  "title": "Pain Record",
  "description": "Draft manual schema for Pain Timing Map / Pain Signal Intelligence. This schema is not runtime code and does not define collection, scraping, ranking, API, automation, or build-command behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pain_id",
    "pain_name",
    "raw_pain",
    "sources",
    "observed_user",
    "audience",
    "primary_domain",
    "current_workaround",
    "timing_curve",
    "pain_market_signal",
    "labels",
    "confidence",
    "responsibility_boundary"
  ],
  "properties": {
    "pain_id": {
      "type": "string",
      "description": "Stable manual identifier, such as P-001."
    },
    "pain_name": {
      "type": "string"
    },
    "raw_pain": {
      "type": "string",
      "description": "Observed pain before interpretation."
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "source_type",
          "evidence_summary"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          },
          "source_reference": {
            "type": "string"
          },
          "date_observed": {
            "type": "string"
          },
          "evidence_summary": {
            "type": "string"
          },
          "reliability_notes": {
            "type": "string"
          }
        }
      }
    },
    "observed_user": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "skill_level": {
      "type": "string"
    },
    "primary_domain": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_workaround": {
      "type": "string"
    },
    "timing_curve": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "now",
        "one_month",
        "three_months",
        "six_months",
        "twelve_months"
      ],
      "properties": {
        "now": {
          "$ref": "#/$defs/timingPoint"
        },
        "one_month": {
          "$ref": "#/$defs/timingPoint"
        },
        "three_months": {
          "$ref": "#/$defs/timingPoint"
        },
        "six_months": {
          "$ref": "#/$defs/timingPoint"
        },
        "twelve_months": {
          "$ref": "#/$defs/timingPoint"
        }
      }
    },
    "pain_market_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pain_intensity",
        "visible_population",
        "market_size",
        "willingness_to_pay",
        "unsolvedness",
        "growth_potential",
        "timing_advantage",
        "user_fit",
        "llm_absorption_risk",
        "differentiation_need",
        "sales_friction",
        "build_burden",
        "avoidance_conflict"
      ],
      "properties": {
        "pain_intensity": {
          "$ref": "#/$defs/score"
        },
        "visible_population": {
          "$ref": "#/$defs/score"
        },
        "market_size": {
          "$ref": "#/$defs/score"
        },
        "willingness_to_pay": {
          "$ref": "#/$defs/score"
        },
        "unsolvedness": {
          "$ref": "#/$defs/score"
        },
        "growth_potential": {
          "$ref": "#/$defs/score"
        },
        "timing_advantage": {
          "$ref": "#/$defs/score"
        },
        "user_fit": {
          "$ref": "#/$defs/score"
        },
        "llm_absorption_risk": {
          "$ref": "#/$defs/score"
        },
        "differentiation_need": {
          "$ref": "#/$defs/score"
        },
        "sales_friction": {
          "$ref": "#/$defs/score"
        },
        "build_burden": {
          "$ref": "#/$defs/score"
        },
        "avoidance_conflict": {
          "$ref": "#/$defs/score"
        }
      }
    },
    "existing_alternatives": {
      "type": "string"
    },
    "composable_with": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "immediate_ev": {
      "type": "string",
      "description": "Expected value as decision material only."
    },
    "suggested_use": {
      "type": "string",
      "description": "Non-command use, such as watch, compare, combine, or gather more evidence."
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "STRONG SIGNAL",
          "EARLY SIGNAL",
          "WATCH",
          "NICHE SIGNAL",
          "ABSORPTION RISK",
          "DIFFERENTIATION REQUIRED",
          "USER-FIT SIGNAL",
          "LOW USER FIT",
          "VALIDATION CANDIDATE",
          "NO BUILD SUGGESTION",
          "COMBINE"
        ]
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "Low",
        "Medium-low",
        "Medium",
        "Medium-high",
        "High"
      ]
    },
    "responsibility_boundary": {
      "type": "string",
      "description": "Must preserve that the build decision remains with the Decision Owner."
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "timingPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score"
      ],
      "properties": {
        "score": {
          "$ref": "#/$defs/score"
        },
        "stage": {
          "type": "string",
          "enum": [
            "signal",
            "emerging",
            "spreading",
            "saturated",
            "absorbed",
            "unknown"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
